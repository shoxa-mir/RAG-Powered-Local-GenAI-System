FROM nvidia/cuda:12.1.0-devel-ubuntu22.04 AS builder

# Install Python and build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev python3-setuptools \
    build-essential cmake ninja-build git \
    && rm -rf /var/lib/apt/lists/*

# Build llama-cpp-python with CUDA
ENV CMAKE_ARGS="-DGGML_CUDA=on"
ENV CUDACXX=/usr/local/cuda/bin/nvcc
# Register CUDA driver stub so linker finds libcuda.so and libcuda.so.1
RUN echo "/usr/local/cuda/lib64/stubs" > /etc/ld.so.conf.d/cuda-stubs.conf && ldconfig
RUN pip3 install --no-cache-dir "llama-cpp-python[server]>=0.3.0"

# --- Runtime stage ---
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.10/dist-packages /usr/local/lib/python3.10/dist-packages
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app

# Copy server script and config
COPY serve_llm.py config.json ./

EXPOSE 8000

CMD ["python3", "serve_llm.py"]
