# All services run locally — no external API keys needed.

# Qdrant (vector DB)
QDRANT_HOST=localhost

# LLM server (llama-cpp-python, started via serve_llm.py)
LLM_BASE_URL=http://localhost:8000/v1

# For Docker Compose, these are set automatically:
#   QDRANT_HOST=qdrant
#   LLM_BASE_URL=http://llm:8000/v1
